{
  "routes": [
    {
      "route": "/",
      "redirect": "/login"
    },
    {
      "route": "/login/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/portal/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/login",
      "rewrite": "/login/index.html"
    },
    {
      "route": "/login/*",
      "rewrite": "/login/index.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/dashboard/*",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/register",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/register/*",
      "rewrite": "/portal/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/login/assets/*", "/portal/*"]
  }
}
