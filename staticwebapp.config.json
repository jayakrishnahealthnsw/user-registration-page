{
  "routes": [
    {
      "route": "/",
      "redirect": "/login"
    },
    {
      "route": "/login",
      "rewrite": "/login/index.html"
    },
    {
      "route": "/login/*",
      "rewrite": "/login/index.html",
      "excludedPaths": ["/login/assets/*"]
    },
    {
      "route": "/dashboard",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/dashboard/*",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/register",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/register/*",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/portal/*",
      "rewrite": "/portal/index.html",
      "excludedPaths": ["/portal/*.js", "/portal/*.css", "/portal/*.png", "/portal/*.svg", "/portal/*.ico", "/portal/*.json", "/portal/*.woff", "/portal/*.woff2"]
    }
  ]
}
