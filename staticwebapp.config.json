{
  "routes": [
    {
      "route": "/",
      "redirect": "/login"
    },
    {
      "route": "/login/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/portal/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    { "route": "/nswhp-logo.png", "rewrite": "/portal/nswhp-logo.png" },
    { "route": "/HealthLink.png", "rewrite": "/portal/HealthLink.png" },
    { "route": "/pathworks.png", "rewrite": "/portal/pathworks.png" },
    { "route": "/more_ids.png", "rewrite": "/portal/more_ids.png" },
    { "route": "/favicon.ico", "rewrite": "/portal/favicon.ico" },
    {
      "route": "/login",
      "rewrite": "/login/index.html"
    },
    {
      "route": "/login/*",
      "rewrite": "/login/index.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/dashboard/*",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/register",
      "rewrite": "/portal/index.html"
    },
    {
      "route": "/register/*",
      "rewrite": "/portal/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/login/assets/*", "/portal/*"]
  }
}
